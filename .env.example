# MillionTwigs — Environment Variables Template
# ─────────────────────────────────────────────
# SETUP:
#   cp .env.example .env
#   nano .env                         # fill in your values
#   python -m src.config.credentials  # verify everything is set
#
# All credentials load automatically via python-dotenv (pip install python-dotenv).
# This file is safe to commit. The .env file is in .gitignore and never committed.
#
# Full registration guide: docs/credentials_guide.md

# ── Google Earth Engine ───────────────────────────────────────────────────────
# Register: https://code.earthengine.google.com/register
# Then run: earthengine authenticate
GEE_PROJECT=your-google-cloud-project-id

# ── Copernicus Dataspace (Sentinel-2) ─────────────────────────────────────────
# Register: https://dataspace.copernicus.eu
COPERNICUS_USER=your_email@example.com
COPERNICUS_PASSWORD=your_password

# ── USGS EarthExplorer (Landsat) ──────────────────────────────────────────────
# Register: https://ers.cr.usgs.gov/register
LANDSATXPLORE_USERNAME=your_usgs_username
LANDSATXPLORE_PASSWORD=your_usgs_password

# ── NASA Earthdata (GEDI LiDAR, MODIS) ───────────────────────────────────────
# Register: https://urs.earthdata.nasa.gov/users/new
EARTHDATA_USERNAME=your_earthdata_username
EARTHDATA_PASSWORD=your_earthdata_password

# ── ISRO Bhuvan / NRSC ───────────────────────────────────────────────────────
# Register: https://bhuvan-app1.nrsc.gov.in/mda/  (approval: 1-3 working days)
BHUVAN_USER=your_bhuvan_email
BHUVAN_PASSWORD=your_bhuvan_password
